# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*

# env files — never commit API keys
.env
.env.local
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime training logs (collected per-machine; aggregated later for fine-tuning).
# `/data/*` not `/data/`: git never descends into an excluded directory, so a negation below it
# would be dead. The held-out eval set is SOURCE, not output — it defines what "the model got
# better" means, it must travel between machines, and check-data.mjs reads it to keep the
# training data away from it.
/data/*
!/data/eval-cases.json

# fine-tuning: local venv, downloaded bases, adapters, merged/GGUF outputs
/.venv-ft/
/models/
/llama.cpp/
__pycache__/
*.pyc
# training logs are per-machine progress output, regenerated each run
/train-*.log

# personal Claude Code permission overrides (per-machine)
/.claude/settings.local.json

# local env backups
.env.local.bak

# training logs (local, noisy)
train-*.log
