# Copy this file to .env.local and configure ONE of the setups below.
# With nothing configured, the app runs in demo mode (sample plan, assistant disabled).

# ── Setup A: Claude API (best quality) ──────────────────────────────────────
# Get a key at https://platform.claude.com/ → API Keys.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# ── Setup B: Local AI — free, runs on your own machine ──────────────────────
# 1. Install LM Studio (https://lmstudio.ai), download a model (8B+ recommended)
# 2. Open its Developer tab → Start Server
# 3. Uncomment the lines below and restart `npm run dev`
# AI_PROVIDER=local
# LOCAL_AI_URL=http://localhost:1234/v1
# For Ollama instead: LOCAL_AI_URL=http://localhost:11434/v1
# Optional: pin a specific model name as shown in LM Studio
# LOCAL_AI_MODEL=local-model

# ── Setup C: Free/cheap open models via OpenRouter (e.g. Kimi K2) ───────────
# 1. Create a free account at https://openrouter.ai → Keys
# 2. Uncomment and paste your key:
# AI_PROVIDER=local
# LOCAL_AI_URL=https://openrouter.ai/api/v1
# LOCAL_AI_MODEL=moonshotai/kimi-k2:free
# LOCAL_AI_API_KEY=sk-or-...
