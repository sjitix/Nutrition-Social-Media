{
  "name": "nutriflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:engine": "esbuild scripts/test-engine.mts --bundle --platform=node --format=esm --tsconfig=tsconfig.json --outfile=node_modules/.cache/test-engine.mjs --log-level=error && node node_modules/.cache/test-engine.mjs",
    "build:nutrients": "esbuild scripts/build-nutrients.mts --bundle --platform=node --format=esm --tsconfig=tsconfig.json --outfile=node_modules/.cache/build-nutrients.mjs --log-level=error && node node_modules/.cache/build-nutrients.mjs",
    "eval:assistant": "esbuild scripts/eval-assistant.mts --bundle --platform=node --format=esm --tsconfig=tsconfig.json --outfile=node_modules/.cache/eval-assistant.mjs --log-level=error && node node_modules/.cache/eval-assistant.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
